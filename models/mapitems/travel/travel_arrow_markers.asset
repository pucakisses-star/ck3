pdxmesh = {
	name = "travel_arrow_destination_marker_mesh"
	file = "travel_arrow_marker.mesh"
	scale = 0.8
	
	meshsettings =
	{
		shader = travel_arrow_marker
		texture_diffuse = "travel_arrow_marker.dds"
		texture_normal = "null_normal.dds"
		texture_specular = "null_gloss.dds"
		shader_file = "gfx/FX/pdxmesh.shader"
	}
}

